<!DOCTYPE html>
<html lang="en">
    <%- include('partials/head', {title}) %>

    <body>
    <%- include('partials/nav') %>
    <section class="container">
        <h1>Chats</h1>

        <ul class="messages">
            <% messages.forEach(msg=> { %>
             <li><span> <%= msg.username %>  said <%= msg.message %> </span> <a href="user/<%= msg.id %>">See More</a></li> 
            <% }); %>

        </ul>

    </section>

    <%- include('partials/footer') %>
</body>
</html>